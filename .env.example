NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
SENTRY_RELEASE=
SNYK_TOKEN=
ESG_DISCOVERY_PROVIDER=openstreetmap
ESG_USER_AGENT=EcoPulse/0.1 (+https://github.com/prof-guifonseca/ecopulse)
NEXT_PUBLIC_MAP_STYLE_URL=
# Origem pública do deploy (ex.: https://ecopulse.vercel.app) — usada para URLs
# absolutas das imagens Open Graph em /s. Sem isso, as prévias usam caminho relativo.
NEXT_PUBLIC_SITE_URL=
NEXT_PUBLIC_ENABLE_LIVE_ESG_DISCOVERY=true
NEXT_PUBLIC_ENABLE_DEMO_DATA=false
OPEN_FOOD_FACTS_USER_AGENT=EcoPulse/0.1 (+https://github.com/prof-guifonseca/ecopulse)
# Backend opcional (Supabase free tier). Sem isto o app segue local-first.
# Server-side (BFF, service-role — ignora RLS): persistência durável.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Client-side (login anônimo da Fase B). Use os MESMOS valores do projeto, mas
# expostos ao browser (anon key é pública por design; protegida por RLS).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
