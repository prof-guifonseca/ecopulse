{
  "name": "ecopulse-next",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit --incremental false",
    "test": "npm run test:unit",
    "test:unit": "vitest run",
    "test:e2e": "playwright test --project=chromium",
    "test:e2e:all": "playwright test --project=chromium --project=firefox --project=webkit",
    "test:a11y": "playwright test --project=a11y",
    "analyze": "next experimental-analyze --output",
    "audit": "npm audit --audit-level=moderate",
    "snyk": "snyk test --dev --severity-threshold=medium",
    "snyk:code": "snyk code test --severity-threshold=medium",
    "check": "npm run lint && npm run typecheck && npm run test:unit && npm run build && npm run test:e2e && npm run audit",
    "tokens:gen": "node scripts/gen-tokens.mjs",
    "tokens:check": "node scripts/gen-tokens.mjs && git diff --exit-code -- src/types/tokens.ts",
    "overnight": "node scripts/overnight.mjs",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{js,cjs,mjs,json,css}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.3.0",
    "@sentry/nextjs": "10.58.0",
    "@supabase/supabase-js": "^2.107.0",
    "@zxing/browser": "^0.1.5",
    "@zxing/library": "^0.21.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.8.0",
    "maplibre-gl": "5.24.0",
    "next": "16.2.6",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-map-gl": "8.1.1",
    "tailwind-merge": "^3.5.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.11.3",
    "@eslint/compat": "^2.1.0",
    "@playwright/test": "1.59.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "10.3.0",
    "eslint-config-next": "16.2.6",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.4",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "snyk": "1.1304.2",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.5"
  },
  "overrides": {
    "postcss": "8.5.14"
  }
}
